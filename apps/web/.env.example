# ---------------------------------------------------------------------------
# apps/web environment variables
#
# Copy this file to .env.local for local development.
# Never commit .env.local — it may contain real credentials.
# ---------------------------------------------------------------------------

# ---- Control plane ----------------------------------------------------------

# Base URL of the Lantern control-plane API (server-side only).
LANTERN_API_URL=http://localhost:8080

# Public URL fallback (also used client-side for the API base URL).
NEXT_PUBLIC_API_URL=http://localhost:8080

# ---- Bridge URLs (not secret — just service addresses) ---------------------
# The URLs are public (just localhost ports); NEXT_PUBLIC_* is fine here.

NEXT_PUBLIC_LANTERN_BRIDGE_URL=http://localhost:3100
NEXT_PUBLIC_LANTERN_IMESSAGE_BRIDGE_URL=http://localhost:3200

# ---- Bridge tokens (SERVER-SIDE ONLY — NOT NEXT_PUBLIC) --------------------
# Match these to LANTERN_BRIDGE_TOKEN on the bridge process.
# Leave empty to skip token auth (bridge must also have its token unset).
# MUST NOT use NEXT_PUBLIC_ prefix — that ships the value to the browser.

LANTERN_BRIDGE_TOKEN=
LANTERN_IMESSAGE_BRIDGE_TOKEN=

# Optional: override bridge URL server-side (when the bridge is on a
# different host than the browser can reach for WebSocket connections).
# LANTERN_BRIDGE_URL=http://bridge-host:3100
# LANTERN_IMESSAGE_BRIDGE_URL=http://imessage-bridge-host:3200

# ---- Auth -------------------------------------------------------------------
# NEXT_PUBLIC_DEMO_MODE=0
