<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>LISTEN_ADDR</key>
		<string>0.0.0.0:50054</string>
		<key>RUNTIME_BACKEND</key>
		<string>docker</string>
		<key>BUNDLE_S3_ENDPOINT</key>
		<string>http://localhost:9000</string>
		<key>BUNDLE_S3_BUCKET</key>
		<string>lantern-bundles</string>
		<key>NODE_ADVERTISE_ADDR</key>
		<string>localhost:50054</string>
		<key>NODE_REGION</key>
		<string>local</string>
		<key>NODE_ZONE</key>
		<string>local-a</string>
		<key>LOG_LEVEL</key>
		<string>info</string>
		<key>PATH</key>
		<string>/opt/homebrew/bin:/usr/local/bin:__HOME__/.cargo/bin:/opt/homebrew/opt/go/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
	</dict>
	<key>KeepAlive</key>
	<dict>
		<key>Crashed</key>
		<true/>
		<key>SuccessfulExit</key>
		<false/>
	</dict>
	<key>Label</key>
	<string>dev.lantern.runtime-manager</string>
	<key>ProgramArguments</key>
	<array>
		<string>__REPO_ROOT__/scripts/launchd/run-microservice.sh</string>
		<string>runtime-manager</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>__HOME__/Library/Logs/Lantern/runtime-manager.err.log</string>
	<key>StandardOutPath</key>
	<string>__HOME__/Library/Logs/Lantern/runtime-manager.out.log</string>
	<key>ThrottleInterval</key>
	<integer>15</integer>
	<key>WorkingDirectory</key>
	<string>__REPO_ROOT__</string>
</dict>
</plist>
